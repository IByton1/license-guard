{
  "name": "license-guard",
  "version": "0.1.0",
  "description": "Offline license compliance checks for npm dependency trees",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "license-guard": "dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "build": "tsup",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run test:pack",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "release:verify": "node scripts/verify-release.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:pack": "node scripts/verify-package.mjs",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "license",
    "compliance",
    "spdx",
    "audit",
    "ci",
    "dependencies",
    "npm"
  ],
  "engines": {
    "node": ">=18.3.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IByton1/license-guard.git"
  },
  "bugs": {
    "url": "https://github.com/IByton1/license-guard/issues"
  },
  "homepage": "https://github.com/IByton1/license-guard#readme",
  "dependencies": {
    "picocolors": "^1.1.1",
    "spdx-expression-parse": "^4.0.0",
    "spdx-license-ids": "^3.0.23"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^18.19.130",
    "@types/spdx-expression-parse": "^4.0.0",
    "@vitest/coverage-v8": "3.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "3.2.7"
  },
  "overrides": {
    "tsup": {
      "esbuild": "0.27.2"
    }
  }
}
